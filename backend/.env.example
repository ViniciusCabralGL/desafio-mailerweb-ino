# App
APP_NAME="MailerWeb Room Booking"
DEBUG=false

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mailerweb

# JWT
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Email SMTP
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@mailerweb.com
SMTP_FROM_NAME=MailerWeb Booking
SMTP_TLS=false

# Worker
OUTBOX_RETRY_LIMIT=3
OUTBOX_BATCH_SIZE=10
